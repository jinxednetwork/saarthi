# Saarthi — environment variables
# Copy to `.env.local` (gitignored) and fill in. The app runs fully without a
# key: the Assistant, document parsing, and briefs fall back to the scripted
# demo brain and mock data. Add the key to activate real Gemini AI.

# Google Generative AI (Gemini) — server-only, never exposed to the client (§14).
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
