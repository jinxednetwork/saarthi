# ============================================================================
# Saarthi — environment configuration
# Copy to .env.local (app) / .env (worker, functions) and fill in.
# NEVER commit real values. No secret prefixed NEXT_PUBLIC_ may be sensitive.
# ============================================================================

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------
# "emulator" = run fully local against Firebase emulators + mock AI clients.
# "cloud"    = use real GCP services (requires the keys below).
SAARTHI_MODE=emulator
NODE_ENV=development

# When true, worker/app use MockAiClient instead of calling Gemini/Vertex.
# Lets the whole pipeline run offline with deterministic canned responses.
SAARTHI_MOCK_AI=true

# ---------------------------------------------------------------------------
# Google Cloud core (§3.2)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=saarthi-dev
GCP_REGION=asia-south1
# Path to a service-account JSON key (server-side only). Leave blank on Cloud Run
# (uses the attached service account via ADC).
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------------
# Firebase (client SDK — safe to expose; these are NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=saarthi-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=saarthi-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=saarthi-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Point the client SDK at local emulators when SAARTHI_MODE=emulator.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# ---------------------------------------------------------------------------
# AI models (§8.8) — server-side only, routed through /api, never client-side
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_LOCATION=asia-south1
# Cloud Speech-to-Text uses ADC (GOOGLE_APPLICATION_CREDENTIALS); no separate key.

# Indic-language fallback for code-mixed voice notes (§3.5)
SARVAM_API_KEY=

# ---------------------------------------------------------------------------
# BigQuery (§6.2) — analytical joins against public datasets
# ---------------------------------------------------------------------------
BIGQUERY_DATASET=saarthi_analytics
BIGQUERY_PUBLIC_DATASET=saarthi_public

# ---------------------------------------------------------------------------
# Google Maps (§3.3) — Maps JS + Places (client key, restrict by HTTP referrer)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Intake channels (§7)
# ---------------------------------------------------------------------------
# WhatsApp Business Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# X / Twitter API v2 (pay-per-use)
TWITTER_BEARER_TOKEN=
TWITTER_TARGET_HANDLE=@Saarthi_NewDelhi

# Reddit (snoowrap OAuth app — free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=saarthi:v0.1 (by /u/your_user)

# Widget intake shared secret (origin-scoped)
WIDGET_SHARED_SECRET=

# ---------------------------------------------------------------------------
# Identifier hashing (§14) — per-constituency salt for citizen id hashing
# ---------------------------------------------------------------------------
CITIZEN_ID_HASH_SALT=change-me-per-constituency

# ---------------------------------------------------------------------------
# Pub/Sub topics (§5) — internal event bus
# ---------------------------------------------------------------------------
PUBSUB_TOPIC_SUBMISSION_CREATED=submission-created
PUBSUB_TOPIC_CLUSTER_UPDATED=cluster-updated
