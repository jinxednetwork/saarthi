# Saarthi — environment variables
# Copy to `.env.local` (gitignored) and fill in. The app runs fully without any
# of these: the Assistant, document parsing, and briefs fall back to the scripted
# demo brain and mock data. Configure a Gemini backend to activate real AI.

# --- Gemini backend (server-only, never exposed to the client, §14). Powers the
# Assistant RAG, document parsing, intake classification, and photo/voice AI.
# The provider picks a backend in this order (app/src/lib/ai/gemini.ts): ---

# 1) PREFERRED — Vertex AI via ADC (no key). Set the project; the region
#    defaults to us-central1. Auth comes from `gcloud auth application-default
#    login` locally, or the runtime service account on Cloud Run / App Hosting
#    (which set GOOGLE_CLOUD_PROJECT for you — so Vertex activates automatically
#    in production). Needs aiplatform.googleapis.com enabled + roles/aiplatform.user.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# 2) FALLBACK — AI Studio key. Used only if no Vertex project is set. Free-tier
#    keys are rate-limited (~20 flash requests/day). https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Social intake (R6a) — all optional; without them, intake runs on labelled
# sample posts + a keyword classifier so the pipeline is still demoable. ---

# Reddit application-only OAuth (free). Register a "script"/"web" app at
# https://www.reddit.com/prefs/apps to get the client id + secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Apify token for the X/Twitter scraper actor (pay-per-result). https://apify.com
APIFY_TOKEN=

# --- Firestore (R7a) — the real data layer for tickets + intake signals. ---
# On Cloud Run / Firebase App Hosting this activates automatically via ADC
# (GOOGLE_CLOUD_PROJECT / K_SERVICE are set for you). Locally, set one of:
#   FIREBASE_PROJECT_ID=<your-project>            # + GOOGLE_APPLICATION_CREDENTIALS=path/to/sa.json
#   FIRESTORE_EMULATOR_HOST=localhost:8080         # to use the local emulator
# Unset → the app uses the in-memory demo stores (offline dev unaffected).
FIREBASE_PROJECT_ID=
