# Saarthi — environment variables
# Copy to `.env.local` (gitignored) and fill in. The app runs fully without a
# key: the Assistant, document parsing, and briefs fall back to the scripted
# demo brain and mock data. Add the key to activate real Gemini AI.

# Google Generative AI (Gemini) — server-only, never exposed to the client (§14).
# Powers the Assistant RAG, document parsing, and intake classification/embeddings.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Social intake (R6a) — all optional; without them, intake runs on labelled
# sample posts + a keyword classifier so the pipeline is still demoable. ---

# Reddit application-only OAuth (free). Register a "script"/"web" app at
# https://www.reddit.com/prefs/apps to get the client id + secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Apify token for the X/Twitter scraper actor (pay-per-result). https://apify.com
APIFY_TOKEN=
